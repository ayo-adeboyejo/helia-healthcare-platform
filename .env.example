# ─────────────────────────────────────────────────────────────────────────────
# Helia — Environment Variables
#
# For local development:
#   cp .env.example .env
#   docker compose up --build
#
# For AWS production:
#   Set ENVIRONMENT=production
#   Sensitive values are loaded from AWS Secrets Manager automatically
#   Only non-sensitive config needs to be set here
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
# development → uses .env file, MinIO, Mailhog, no AWS required
# production  → uses AWS Secrets Manager, S3, SES
ENVIRONMENT=development
LOG_LEVEL=info
ALLOWED_ORIGINS=*

# ── AWS (only required when ENVIRONMENT=production) ────────────────────────────
AWS_REGION=ap-south-1
S3_BUCKET=helia-files
SES_FROM_EMAIL=noreply@helia.health

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=helia
POSTGRES_PASSWORD=helia_dev_password
POSTGRES_AUTH_DB=authdb
POSTGRES_USER_DB=userdb
POSTGRES_APPOINTMENT_DB=appointmentdb
POSTGRES_PAYMENT_DB=paymentdb

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_USER=helia
MONGO_PASSWORD=helia_dev_password
MONGO_DB=helia_records

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=helia_dev_redis

# ── Elasticsearch ─────────────────────────────────────────────────────────────
ELASTIC_PASSWORD=helia_dev_elastic

# ── MinIO (local S3 replacement — development only) ───────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# ── JWT (used directly in development, loaded from Secrets Manager in production)
JWT_SECRET=dev_jwt_secret_change_this_in_production_use_long_random_string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
