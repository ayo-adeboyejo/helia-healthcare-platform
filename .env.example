# ─────────────────────────────────────────────────────────────────────────────
# Helia — Environment Variables Template
#
# This file is safe to commit to git — it contains no secrets.
#
# On the EC2 instance, DO NOT copy this file manually.
# Instead run the deploy script which fetches all secrets from
# AWS Secrets Manager and generates the .env automatically:
#
#   ./scripts/deploy.sh
#
# The deploy script writes a .env containing both this non-sensitive
# config AND the secrets fetched from AWS Secrets Manager.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=production
LOG_LEVEL=info
AWS_REGION=ap-south-1
ALLOWED_ORIGINS=http://<your-elastic-ip>

# ── AWS services ──────────────────────────────────────────────────────────────
S3_BUCKET=helia-files
SES_FROM_EMAIL=noreply@helia.health

# ── PostgreSQL (non-sensitive config only) ─────────────────────────────────────
# Credentials come from AWS Secrets Manager via deploy.sh
POSTGRES_USER=helia
POSTGRES_AUTH_DB=authdb
POSTGRES_USER_DB=userdb
POSTGRES_APPOINTMENT_DB=appointmentdb
POSTGRES_PAYMENT_DB=paymentdb

# ── MongoDB (non-sensitive config only) ────────────────────────────────────────
MONGO_USER=helia
MONGO_DB=helia_records
